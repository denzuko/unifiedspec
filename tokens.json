{
  "$schema": "./tokens.schema.json",
  "$metadata": {
    "name": "Unified Design System",
    "version": "2.1.0",
    "description": "Design tokens for the Unified Design System. Four lineages: Solarized (tonal palette), Okabe-Ito (semantic color), Plan 9/Acme (structure), Solaris/CDE (chrome).",
    "authors": [
      "Da Planet Security",
      "unifiedspec.org"
    ],
    "license": "BSD-2-Clause"
  },
  "palette": {
    "$description": "Layer 0 \u2014 raw palette constants. Never reference these in component code. Use semantic tokens instead.",
    "solarized": {
      "$description": "Ethan Schoonover 2011. CIELAB-calibrated. 16 colors.",
      "base03": {
        "$type": "color",
        "$value": "#002b36",
        "$description": "Dark background"
      },
      "base02": {
        "$type": "color",
        "$value": "#073642",
        "$description": "Dark panel surface"
      },
      "base01": {
        "$type": "color",
        "$value": "#586e75",
        "$description": "Optional emphasis (dark), body text (light)"
      },
      "base00": {
        "$type": "color",
        "$value": "#657b83",
        "$description": "Body text (dark), optional emphasis (light)"
      },
      "base0": {
        "$type": "color",
        "$value": "#839496",
        "$description": "Body text default"
      },
      "base1": {
        "$type": "color",
        "$value": "#93a1a1",
        "$description": "Body text (dark mode, v2 fix: 5.61:1 on base03)"
      },
      "base2": {
        "$type": "color",
        "$value": "#eee8d5",
        "$description": "Light panel surface"
      },
      "base3": {
        "$type": "color",
        "$value": "#fdf6e3",
        "$description": "Light background"
      },
      "yellow": {
        "$type": "color",
        "$value": "#b58900",
        "$description": "Syntax: variables"
      },
      "orange": {
        "$type": "color",
        "$value": "#cb4b16",
        "$description": "Syntax: types"
      },
      "red": {
        "$type": "color",
        "$value": "#dc322f",
        "$description": "Syntax: (available)"
      },
      "magenta": {
        "$type": "color",
        "$value": "#d33682",
        "$description": "Syntax: numbers"
      },
      "violet": {
        "$type": "color",
        "$value": "#6c71c4",
        "$description": "Syntax: (available)"
      },
      "blue": {
        "$type": "color",
        "$value": "#268bd2",
        "$description": "Syntax: functions"
      },
      "cyan": {
        "$type": "color",
        "$value": "#2aa198",
        "$description": "Syntax: strings, brand"
      },
      "green": {
        "$type": "color",
        "$value": "#859900",
        "$description": "Syntax: keywords"
      }
    },
    "okabe-ito": {
      "$description": "Okabe & Ito 2002. CVD-safe under deuteranopia, protanopia, tritanopia.",
      "blue": {
        "$type": "color",
        "$value": "#0072b2",
        "$description": "Primary actions (light)"
      },
      "skyblue": {
        "$type": "color",
        "$value": "#56b4e9",
        "$description": "Info / primary (dark)"
      },
      "green": {
        "$type": "color",
        "$value": "#009e73",
        "$description": "Success"
      },
      "orange": {
        "$type": "color",
        "$value": "#e69f00",
        "$description": "Warning / caution"
      },
      "vermillion": {
        "$type": "color",
        "$value": "#d55e00",
        "$description": "Danger / error"
      },
      "pink": {
        "$type": "color",
        "$value": "#cc79a7",
        "$description": "Special / beta"
      },
      "yellow": {
        "$type": "color",
        "$value": "#f0e442",
        "$description": "Supplementary only \u2014 fails tritanopia at small sizes"
      }
    },
    "plan9": {
      "$description": "Plan 9 / Acme color model. Rob Pike, Bell Labs 1992.",
      "body": {
        "$type": "color",
        "$value": "#ffffea",
        "$description": "Acme window body"
      },
      "tag": {
        "$type": "color",
        "$value": "#eaffff",
        "$description": "Acme tag bar"
      },
      "sel": {
        "$type": "color",
        "$value": "#9eeeee",
        "$description": "Selection / focus fill"
      },
      "scroll": {
        "$type": "color",
        "$value": "#aaaaaa",
        "$description": "Worm strip (light)"
      }
    },
    "solaris-cde": {
      "$description": "Sun Microsystems CDE 1993, OpenSolaris 2008.",
      "teal": {
        "$type": "color",
        "$value": "#008080",
        "$description": "CDE titlebar"
      },
      "teal-dk": {
        "$type": "color",
        "$value": "#005555",
        "$description": "CDE titlebar border"
      },
      "orange": {
        "$type": "color",
        "$value": "#d04000",
        "$description": "Sun logo block"
      },
      "motif-gray": {
        "$type": "color",
        "$value": "#c0c0c0",
        "$description": "Motif panel"
      },
      "motif-lt": {
        "$type": "color",
        "$value": "#e8e8e8",
        "$description": "Motif highlight"
      }
    }
  },
  "semantic": {
    "$description": "Layer 1 \u2014 semantic tokens. Always use these in component code, never raw palette values.",
    "color": {
      "background": {
        "base": {
          "$type": "color",
          "$value": "{palette.solarized.base3}",
          "$description": "Content area \u2014 light: base3 (#fdf6e3), dark: base03 (#002b36)"
        },
        "surface": {
          "$type": "color",
          "$value": "{palette.solarized.base2}",
          "$description": "Panels, sidebar"
        },
        "tag": {
          "$type": "color",
          "$value": "#eafaff",
          "$description": "Acme tag bar \u2014 P9 tag blended with Solarized"
        },
        "titlebar": {
          "$type": "color",
          "$value": "{palette.solaris-cde.teal}",
          "$description": "CDE application chrome"
        },
        "sel": {
          "$type": "color",
          "$value": "{palette.plan9.sel}",
          "$description": "Selection / focus fill"
        },
        "code": {
          "$type": "color",
          "$value": "{palette.solarized.base02}",
          "$description": "Code block surface"
        }
      },
      "foreground": {
        "head": {
          "$type": "color",
          "$value": "{palette.solarized.base03}",
          "$description": "Headings \u2014 13.92:1 on base3 light"
        },
        "body": {
          "$type": "color",
          "$value": "{palette.solarized.base01}",
          "$description": "Body text \u2014 light: 4.99:1. Dark: base1 5.61:1 (v2 fix)"
        },
        "muted": {
          "$type": "color",
          "$value": "{palette.solarized.base00}",
          "$description": "Secondary text"
        },
        "faint": {
          "$type": "color",
          "$value": "{palette.solarized.base1}",
          "$description": "Decorative / disabled \u2014 2.79:1, intentional"
        },
        "on-dark": {
          "$type": "color",
          "$value": "{palette.solarized.base3}",
          "$description": "Text on dark surfaces (titlebar, dark card heads)"
        }
      },
      "semantic": {
        "primary": {
          "$type": "color",
          "$value": "{palette.okabe-ito.blue}",
          "$description": "Primary actions. Dark: skyblue."
        },
        "success": {
          "$type": "color",
          "$value": "{palette.okabe-ito.green}",
          "$description": "Success, ok states"
        },
        "warning": {
          "$type": "color",
          "$value": "{palette.okabe-ito.orange}",
          "$description": "Caution, warning"
        },
        "danger": {
          "$type": "color",
          "$value": "{palette.okabe-ito.vermillion}",
          "$description": "Error, destructive actions"
        },
        "info": {
          "$type": "color",
          "$value": "{palette.okabe-ito.skyblue}",
          "$description": "Informational"
        },
        "special": {
          "$type": "color",
          "$value": "{palette.okabe-ito.pink}",
          "$description": "Beta, special states"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "#999999",
          "$description": "Standard border"
        },
        "light": {
          "$type": "color",
          "$value": "#cccccc",
          "$description": "Subtle border"
        },
        "tag": {
          "$type": "color",
          "$value": "#b8d8d8",
          "$description": "Tag bar border"
        },
        "titlebar": {
          "$type": "color",
          "$value": "{palette.solaris-cde.teal-dk}",
          "$description": "CDE titlebar bottom border"
        }
      },
      "syntax": {
        "keyword": {
          "$type": "color",
          "$value": "{palette.solarized.green}",
          "$description": "Keywords"
        },
        "string": {
          "$type": "color",
          "$value": "{palette.solarized.cyan}",
          "$description": "Strings"
        },
        "number": {
          "$type": "color",
          "$value": "{palette.solarized.magenta}",
          "$description": "Numbers"
        },
        "comment": {
          "$type": "color",
          "$value": "{palette.solarized.base01}",
          "$description": "Comments (italic)"
        },
        "function": {
          "$type": "color",
          "$value": "{palette.solarized.blue}",
          "$description": "Functions, methods"
        },
        "variable": {
          "$type": "color",
          "$value": "{palette.solarized.yellow}",
          "$description": "Variables"
        },
        "type": {
          "$type": "color",
          "$value": "{palette.solarized.orange}",
          "$description": "Types, classes"
        }
      },
      "worm": {
        "thumb": {
          "$type": "color",
          "$value": "{palette.plan9.scroll}",
          "$description": "Worm strip thumb \u2014 light: #aaaaaa, dark: #3a5a6a"
        },
        "track": {
          "$type": "color",
          "$value": "#e0e0e0",
          "$description": "Worm strip track \u2014 light. Dark: #031820"
        }
      }
    },
    "typography": {
      "$description": "Two-register font system. UI (Titillium Web / CDE lineage) and mono (Inconsolata / Plan 9 terminal).",
      "font-family": {
        "ui": {
          "$type": "fontFamily",
          "$value": [
            "Titillium Web",
            "Helvetica Neue",
            "Arial",
            "sans-serif"
          ],
          "$description": "UI/display register \u2014 headings, labels, buttons"
        },
        "mono": {
          "$type": "fontFamily",
          "$value": [
            "Inconsolata",
            "Courier New",
            "monospace"
          ],
          "$description": "Technical register \u2014 code, tag bars, tokens, paths"
        }
      },
      "font-size": {
        "$description": "All values in rem (base 16px). Respects browser font size preference per WCAG 1.4.4.",
        "xs": {
          "$type": "dimension",
          "$value": "0.625rem",
          "$description": "10px equivalent \u2014 overlines, badge text"
        },
        "sm": {
          "$type": "dimension",
          "$value": "0.6875rem",
          "$description": "11px equivalent \u2014 nav labels, meta text"
        },
        "base": {
          "$type": "dimension",
          "$value": "0.8125rem",
          "$description": "13px equivalent \u2014 body, code, inputs"
        },
        "md": {
          "$type": "dimension",
          "$value": "0.875rem",
          "$description": "14px equivalent \u2014 UI body, table cells"
        },
        "lg": {
          "$type": "dimension",
          "$value": "1rem",
          "$description": "16px equivalent \u2014 labels, component headers"
        },
        "xl": {
          "$type": "dimension",
          "$value": "1.25rem",
          "$description": "20px equivalent \u2014 subsection titles"
        },
        "2xl": {
          "$type": "dimension",
          "$value": "1.75rem",
          "$description": "28px equivalent \u2014 section headings"
        },
        "3xl": {
          "$type": "dimension",
          "$value": "2.25rem",
          "$description": "36px equivalent \u2014 page headings"
        },
        "4xl": {
          "$type": "dimension",
          "$value": "3.25rem",
          "$description": "52px equivalent \u2014 display / hero"
        }
      }
    },
    "spacing": {
      "$description": "4px base unit. Plan 9 dense convention scaled for modern screens. 8 steps.",
      "1": {
        "$type": "dimension",
        "$value": "4px",
        "$description": "Icon/glyph gaps, badge padding"
      },
      "2": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "Tight element groups"
      },
      "3": {
        "$type": "dimension",
        "$value": "12px",
        "$description": "Cell padding, tag-bar items"
      },
      "4": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Component internal padding"
      },
      "5": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "Card / panel padding"
      },
      "6": {
        "$type": "dimension",
        "$value": "32px",
        "$description": "Between component groups"
      },
      "7": {
        "$type": "dimension",
        "$value": "48px",
        "$description": "Major section gaps, page padding"
      },
      "8": {
        "$type": "dimension",
        "$value": "64px",
        "$description": "Page-level separation"
      }
    },
    "border-radius": {
      "$description": "Split register: 0px for chrome (Plan 9), 2-6px for content (usability).",
      "zero": {
        "$type": "dimension",
        "$value": "0px",
        "$description": "Chrome: titlebars, tag bars, badges, Motif buttons, code blocks"
      },
      "sm": {
        "$type": "dimension",
        "$value": "2px",
        "$description": "Table rows, input borders"
      },
      "md": {
        "$type": "dimension",
        "$value": "4px",
        "$description": "Solid action buttons, dropdowns"
      },
      "lg": {
        "$type": "dimension",
        "$value": "6px",
        "$description": "Content cards, stat panels"
      }
    },
    "breakpoints": {
      "$description": "Used in @media queries only. Never in var() in component CSS. Desktop/tablet first.",
      "sm": {
        "$type": "dimension",
        "$value": "768px",
        "$description": "Tablet portrait floor \u2014 sidebar may collapse"
      },
      "md": {
        "$type": "dimension",
        "$value": "1024px",
        "$description": "Tablet landscape / small desktop \u2014 full layout"
      },
      "lg": {
        "$type": "dimension",
        "$value": "1280px",
        "$description": "Standard desktop \u2014 primary design target"
      }
    }
  }
}